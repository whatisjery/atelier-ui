{
    "name": "atelier-ui",
    "version": "0.1.0",
    "private": false,
    "scripts": {
        "build": "next build",
        "start": "next start",
        "lint:check": "biome lint",
        "lint:fix": "biome lint --fix",
        "test:all": "vitest run",
        "pro:update": "git submodule update --remote src/pro && tsx src/scripts/merge-pro.ts",
        "prebuild": "pnpm pro:merge && tsx src/scripts/build-registry.ts && tsx src/scripts/search-index.ts && tsx src/scripts/generate-timestamps.ts && tsx src/scripts/generate-llms-full.ts",
        "dev": "tsx src/scripts/build-registry.ts && tsx src/scripts/search-index.ts && tsx src/scripts/generate-timestamps.ts && tsx src/scripts/generate-llms-full.ts && next dev",
        "install:vercel": "bash ./bin/init-submodule.sh && pnpm install",
        "scafold-new": "tsx src/scripts/scafold-new.ts"
    },
    "dependencies": {
        "@mdx-js/loader": "^3.1.1",
        "@mdx-js/react": "^3.1.1",
        "@next/mdx": "^16.2.5",
        "@pmndrs/assets": "^1.7.0",
        "@polar-sh/sdk": "^0.47.1",
        "@react-three/drei": "^10.7.7",
        "@react-three/fiber": "^9.6.1",
        "@react-three/postprocessing": "^3.0.4",
        "@t3-oss/env-nextjs": "^0.13.11",
        "@uiw/react-color-colorful": "^2.10.1",
        "@upstash/ratelimit": "^2.0.8",
        "@upstash/redis": "^1.38.0",
        "clsx": "^2.1.1",
        "fast-glob": "^3.3.3",
        "fuse.js": "^7.3.0",
        "gray-matter": "^4.0.3",
        "hast-util-to-jsx-runtime": "^2.3.6",
        "jose": "^6.2.3",
        "js-yaml": "^4.1.1",
        "lenis": "^1.3.23",
        "lucide-react": "^1.14.0",
        "motion": "^12.38.0",
        "next": "16.2.5",
        "next-intl": "^4.11.0",
        "next-themes": "^0.4.6",
        "postprocessing": "^6.39.1",
        "radix-ui": "^1.4.3",
        "react": "19.2.6",
        "react-dom": "19.2.6",
        "react-icons": "^5.6.0",
        "rehype-mdx-code-props": "^3.0.1",
        "remark": "^15.0.1",
        "remark-frontmatter": "^5.0.0",
        "remark-gfm": "^4.0.1",
        "remark-mdx": "^3.1.1",
        "remark-mdx-frontmatter": "^5.2.0",
        "resend": "^6.12.3",
        "shiki": "^4.0.2",
        "sonner": "^2.0.7",
        "suspend-react": "^0.1.3",
        "tailwind-merge": "^3.5.0",
        "three": "^0.184.0",
        "tunnel-rat": "^0.1.2",
        "unist-util-visit": "^5.1.0",
        "usehooks-ts": "^3.1.1",
        "zod": "^4.4.3",
        "zustand": "^5.0.13"
    },
    "devDependencies": {
        "@biomejs/biome": "^2.4.14",
        "@tailwindcss/postcss": "^4.2.4",
        "@tailwindcss/typography": "^0.5.19",
        "@types/js-yaml": "^4.0.9",
        "@types/mdast": "^4.0.4",
        "@types/mdx": "^2.0.13",
        "@types/node": "^25.6.0",
        "@types/react": "^19.2.14",
        "@types/react-dom": "^19.2.3",
        "@types/three": "^0.184.1",
        "@types/unist": "^3.0.3",
        "@vitejs/plugin-react": "^6.0.1",
        "jsdom": "^29.1.1",
        "lefthook": "^2.1.6",
        "raw-loader": "^4.0.2",
        "tailwindcss": "^4.2.4",
        "tsx": "^4.21.0",
        "tw-animate-css": "^1.4.0",
        "typescript": "^6.0.3",
        "vite-tsconfig-paths": "^6.1.1",
        "vitest": "^4.1.5"
    }
}
