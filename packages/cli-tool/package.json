{
    "name": "atelier-ui",
    "version": "1.0.0",
    "files": [
        "dist"
    ],
    "bin": {
        "atelier-ui": "./dist/index.js"
    },
    "keywords": [
        "react",
        "react-three-fiber",
        "r3f",
        "three",
        "threejs",
        "webgl",
        "shaders",
        "motion",
        "ui-components",
        "animations",
        "effects",
        "tailwindcss",
        "copy-paste"
    ],
    "scripts": {
        "build": "tsc",
        "test": "vitest run",
        "dev:add": "cross-env ATELIER_REGISTRY=http://localhost:3000/api/registry tsx src/index.ts add --path test/fixtures/project/components",
        "dev:test": "cross-env ATELIER_REGISTRY=http://localhost:3000/api/registry vitest run"
    },
    "dependencies": {
        "@react-three/drei": "^10.7.7",
        "@react-three/fiber": "^9.6.1",
        "@react-three/postprocessing": "^3.0.4",
        "commander": "^12.0.0",
        "dotenv": "^17.2.3",
        "fs-extra": "^11.0.0",
        "postprocessing": "^6.39.1",
        "three": "^0.182.0"
    },
    "devDependencies": {
        "@types/fs-extra": "^11.0.0",
        "@types/node": "^20.0.0",
        "prettier": "^3.8.0",
        "tsx": "^4.21.0",
        "typescript": "^5.0.0",
        "vitest": "^4.0.17"
    }
}
